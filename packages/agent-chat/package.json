{
  "name": "@mde/agent-chat",
  "version": "1.6.2",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./fake": "./src/fakeAdapter.ts",
    "./types": "./src/types.ts"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json --noEmit",
    "typecheck": "tsc --project tsconfig.json --noEmit",
