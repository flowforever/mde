{
  "name": "mde",
  "version": "1.5.9",
  "description": "A Notion-style Markdown editor with a VS Code-like explorer.",
  "productName": "MDE",
  "private": true,
  "packageManager": "pnpm@10.18.2",
  "type": "module",
  "main": "apps/desktop/out/main/index.js",
  "bin": {
    "mde": "./bin/mde.js"
  },
  "scripts": {
    "dev": "pnpm --filter @mde/desktop dev",
    "start": "pnpm --filter @mde/desktop start",
    "build": "pnpm --filter @mde/desktop build",
    "package": "pnpm --filter @mde/desktop package",
    "dist": "pnpm --filter @mde/desktop dist",
    "dist:mac": "pnpm --filter @mde/desktop dist:mac",
    "dist:win": "pnpm --filter @mde/desktop dist:win",
    "icons:generate": "node scripts/generate-app-icons.mjs",
    "release:github": "pnpm --filter @mde/desktop release:github",
    "release:github:mac": "pnpm --filter @mde/desktop release:github:mac",
    "release:github:win": "pnpm --filter @mde/desktop release:github:win",
    "register:cli": "pnpm link --global",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "test:unit": "vitest run --project unit --testTimeout=30000",
    "test:integration": "vitest run --project integration --testTimeout=30000",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "pnpm --filter @mde/desktop test:e2e",
    "test:e2e:performance": "pnpm --filter @mde/desktop test:e2e:performance",
    "test:e2e:performance:benchmark": "pnpm --filter @mde/desktop test:e2e:performance:benchmark",
    "test": "pnpm run test:unit && pnpm run test:integration && pnpm run test:e2e",
    "docs:screenshots": "pnpm --filter @mde/desktop docs:screenshots",
    "docs:dev": "vitepress dev user-manual",
    "docs:build": "vitepress build user-manual",
    "docs:preview": "vitepress preview user-manual"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^3.2.4",
    "electron": "^41.5.0",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^26.1.0",
    "playwright": "^1.59.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vite": "^6.4.2",
    "vitepress": "^1.6.4",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "uuid": "14.0.0",
    "vite": "$vite"
  }
}
